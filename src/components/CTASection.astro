---
import { fetchCTA } from '../lib/sanity'

interface CTAData {
  _id: string
  titulo: string
  subtitulo: string
  textoBoton: string
  urlBoton: string
  imagenFondoUrl: string
}

const fallbackCTA: CTAData = {
  _id: 'fallback-cta',
  titulo: '¿Listo para solicitar tu presupuesto?',
  subtitulo: 'Brindamos productos de calidad con atención personalizada para productores y empresas agrícolas en Chile.',
  textoBoton: 'Solicitar presupuesto',
  urlBoton: '/cotizar',
  imagenFondoUrl: '',
}

let cta: CTAData

try {
  const data = await fetchCTA()
  cta = data ? {
    _id: data._id,
    titulo: data.titulo,
    subtitulo: data.subtitulo,
    textoBoton: data.textoBoton,
    urlBoton: data.urlBoton,
    imagenFondoUrl: data.imagenFondoUrl,
  } : fallbackCTA
} catch {
  cta = fallbackCTA
}

const bgStyle = cta.imagenFondoUrl
  ? `background-image: url(${cta.imagenFondoUrl})`
  : ''
---

<section class="cta-section relative overflow-hidden">
  <div class="inner-container relative">
    {cta.imagenFondoUrl && <div class="absolute inset-0 bg-cover bg-center" style={bgStyle}></div>}
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--theme-color-3)] to-[var(--theme-color)]" class:list={[cta.imagenFondoUrl && 'bg-opacity-90']}></div>

    <div class="large-container relative z-10 py-16 md:py-24">
      <div class="content-box flex flex-col lg:flex-row items-center justify-between gap-8">
        <div class="text text-white lg:w-2/3">
          <h2 class="text-3xl md:text-4xl font-bold font-['Rethink_Sans',sans-serif] mb-4">{cta.titulo}</h2>
          <h3 class="text-lg md:text-xl text-white/80">{cta.subtitulo}</h3>
        </div>
        <div class="flex-shrink-0">
          <a href={cta.urlBoton} class="theme-btn btn-one inline-flex items-center gap-2 px-8 py-4 bg-[var(--accent-color)] text-gray-900 font-semibold rounded-lg hover:bg-white transition-all duration-300 shadow-lg">
            {cta.textoBoton}
            <i class="fas fa-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
