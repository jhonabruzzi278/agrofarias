---
import { fetchCTA } from '../lib/sanity'

interface CTAData {
  _id: string
  titulo: string
  subtitulo: string
  textoBoton: string
  urlBoton: string
  imagenFondoUrl: string
}

const fallbackCTA: CTAData = {
  _id: 'fallback-cta',
  titulo: 'Solicitar Presupuesto',
  subtitulo: 'Completa tus datos y te enviaremos una cotización personalizada a la brevedad.',
  textoBoton: 'Solicitar presupuesto',
  urlBoton: '/cotizar',
  imagenFondoUrl: '',
}

let cta: CTAData

try {
  const data = await fetchCTA()
  cta = data ? {
    _id: data._id,
    titulo: data.titulo,
    subtitulo: data.subtitulo,
    textoBoton: data.textoBoton,
    urlBoton: data.urlBoton,
    imagenFondoUrl: data.imagenFondoUrl,
  } : fallbackCTA
} catch {
  cta = fallbackCTA
}
---

<section class="cta-section py-16 md:py-20 bg-white">
  <div class="large-container">
    <div class="bg-gray-50 rounded-2xl border border-gray-200 p-8 md:p-12 lg:p-16 flex flex-col lg:flex-row items-center justify-between gap-8">
      <div class="lg:w-2/3 text-center lg:text-left">
        <h2 class="text-2xl md:text-3xl font-bold font-['Rethink_Sans',sans-serif] text-[#111] mb-3">{cta.titulo}</h2>
        <p class="text-gray-600 text-base md:text-lg max-w-xl">{cta.subtitulo}</p>
      </div>
      <div class="flex-shrink-0">
        <a href={cta.urlBoton} class="inline-flex items-center gap-2 px-8 py-4 bg-[var(--theme-color)] text-white font-semibold rounded-xl hover:bg-[var(--theme-color-3)] transition-all duration-300 shadow-md hover:shadow-lg">
          {cta.textoBoton}
          <i class="fas fa-arrow-right text-sm"></i>
        </a>
      </div>
    </div>
  </div>
</section>
