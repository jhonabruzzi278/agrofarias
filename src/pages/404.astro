---
import Layout from '../layouts/Layout.astro';
import HeaderUpper from '../components/HeaderUpper.vue';
import HeaderLower from '../components/HeaderLower.vue';
import Footer from '../components/Footer.vue';
import { fetchCategorias } from '../lib/woocommerce';

let categorias: Array<{ id: number; name: string; slug: string; parent: number }> = [];
try { categorias = await fetchCategorias(); } catch { categorias = []; }
---

<Layout title="Página no encontrada" description="La página que buscas no existe o ha sido movida." noindex>
  <header class="main-header">
    <HeaderUpper client:only="vue" categorias={categorias} />
    <HeaderLower client:only="vue" />
  </header>

  <section class="py-16 text-center min-h-[60vh] flex items-center justify-center">
    <div class="auto-container">
      <div class="max-w-lg mx-auto">
        <div class="w-28 h-28 mx-auto mb-8 bg-gradient-to-br from-[var(--theme-color)] to-[var(--theme-color-2)] rounded-full flex items-center justify-center">
          <i class="fas fa-seedling text-5xl text-white"></i>
        </div>
        <h1 class="text-6xl md:text-8xl font-bold font-['Rethink_Sans',sans-serif] text-[var(--theme-color)] mb-4">404</h1>
        <h2 class="text-2xl font-bold font-['Rethink_Sans',sans-serif] text-[#111] mb-4">Página no encontrada</h2>
        <p class="text-lg text-gray-500 mb-8 max-w-md mx-auto">
          La página que buscas no existe o ha sido movida. Pero no te preocupes, aún puedes explorar nuestros productos.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href="/tienda" class="theme-btn btn-one inline-flex px-8 py-4"><i class="fas fa-store" aria-hidden="true"></i> Ver productos</a>
          <a href="/" class="theme-btn btn-two inline-flex px-8 py-4">Ir al inicio</a>
        </div>
      </div>
    </div>
  </section>

  <section class="highlights-section bg-white py-16">
    <div class="large-container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gray-50 rounded-2xl p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="w-14 h-14 mx-auto mb-5 bg-gradient-to-br from-[var(--theme-color)] to-[var(--theme-color-2)] rounded-full flex items-center justify-center">
            <i class="fas fa-truck text-white text-2xl"></i>
          </div>
          <h5 class="text-base font-bold text-[#111]">Despacho confiable</h5>
          <p class="text-sm text-gray-500 mt-2">Llegamos hasta tu campo o domicilio</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="w-14 h-14 mx-auto mb-5 bg-gradient-to-br from-[var(--theme-color)] to-[var(--theme-color-2)] rounded-full flex items-center justify-center">
            <i class="fas fa-headset text-white text-2xl"></i>
          </div>
          <h5 class="text-base font-bold text-[#111]">Atención personalizada</h5>
          <p class="text-sm text-gray-500 mt-2">Te ayudamos a elegir los mejores productos</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="w-14 h-14 mx-auto mb-5 bg-gradient-to-br from-[var(--theme-color)] to-[var(--theme-color-2)] rounded-full flex items-center justify-center">
            <i class="fas fa-leaf text-white text-2xl"></i>
          </div>
          <h5 class="text-base font-bold text-[#111]">Productos de calidad</h5>
          <p class="text-sm text-gray-500 mt-2">Insumos agrícolas profesionales</p>
        </div>
      </div>
    </div>
  </section>

  <Footer client:only="vue" />
</Layout>
