---
import Layout from '../../layouts/Layout.astro';
import HeaderUpper from '../../components/HeaderUpper.vue';
import HeaderLower from '../../components/HeaderLower.vue';
import QuoteButton from '../../components/QuoteButton.vue';
import ProductCard from '../../components/ProductCard.vue';
import Footer from '../../components/Footer.vue';
import { fetchProductoBySlug, fetchProductosPorCategoria, fetchCategorias } from '../../lib/woocommerce';
import type { ProductoWC } from '../../lib/types';

let categorias: Array<{ id: number; name: string; slug: string; parent: number }> = [];
try { categorias = await fetchCategorias(); } catch { categorias = []; }

const { slug } = Astro.params;
let producto: ProductoWC | null = null;
try {
  const results = await fetchProductoBySlug(slug!);
  producto = results[0] || null;
} catch { producto = null; }

if (!producto) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const cleanDesc = producto.short_description?.replace(/<[^>]*>/g, '').slice(0, 160) || '';
const prodImage = producto.images[0]?.src || '/logo-agrofarias.png';
const prodCanonical = `https://agrofarias.cl/producto/${producto.slug}`;

// Fetch related products from same category (excluding current)
let relacionados: ProductoWC[] = [];
try {
  const catId = producto.categories?.[0]?.id;
  if (catId) {
    const todos = await fetchProductosPorCategoria(catId);
    relacionados = todos.filter(p => p.id !== producto!.id).slice(0, 4);
  }
} catch { relacionados = []; }

// Parse attributes for specs tab
const atributos = producto.attributes || [];
---

<Layout title={producto.name} description={cleanDesc} image={prodImage} canonical={prodCanonical} type="product">
  <header class="main-header">
    <HeaderUpper client:only="vue" categorias={categorias} />
    <HeaderLower client:only="vue" />
  </header>

  <main class="py-12 min-h-[60vh]">
    <div class="large-container">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 flex-wrap">
          <li><a href="/" class="text-gray-500 hover:text-[var(--theme-color)] transition-colors">Inicio</a></li>
          <li class="text-gray-300" aria-hidden="true"><i class="fas fa-chevron-right text-xs"></i></li>
          <li><a href="/tienda" class="text-gray-500 hover:text-[var(--theme-color)] transition-colors">Tienda</a></li>
          <li class="text-gray-300" aria-hidden="true"><i class="fas fa-chevron-right text-xs"></i></li>
          {producto.categories.slice(0, 1).map(cat => (
            <li key={cat.id}><a href={`/categoria/${cat.slug}`} class="text-gray-500 hover:text-[var(--theme-color)] transition-colors">{cat.name}</a></li>
          ))}
          <li class="text-gray-300" aria-hidden="true"><i class="fas fa-chevron-right text-xs"></i></li>
          <li class="text-[var(--theme-color)] font-medium truncate max-w-[200px]">{producto.name}</li>
        </ol>
      </nav>

      <!-- Product Hero -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-16">
        <!-- Image -->
        <div class="animate-fade-in-left">
          <div class="bg-white rounded-2xl border border-gray-200 p-6 lg:p-10 sticky top-24">
            {producto.images.length > 0 ? (
              <img src={producto.images[0].src} alt={producto.name} class="w-full rounded-xl object-contain max-h-[500px] hover:scale-[1.02] transition-transform duration-500" loading="eager" />
            ) : (
              <div class="w-full h-[400px] bg-gray-50 rounded-xl flex items-center justify-center text-gray-400">
                <i class="fas fa-image text-6xl"></i>
              </div>
            )}
            
            <!-- Thumbnail gallery if multiple images -->
            {producto.images.length > 1 && (
              <div class="flex gap-3 mt-4 overflow-x-auto pb-2">
                {producto.images.slice(0, 4).map(img => (
                  <button class="flex-shrink-0 w-20 h-20 rounded-lg border-2 border-gray-100 hover:border-[var(--theme-color)] transition-colors overflow-hidden bg-white p-1">
                    <img src={img.src} alt={producto.name} class="w-full h-full object-contain rounded" loading="lazy" />
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- Info -->
        <div class="animate-fade-in-right">
          <!-- Category badge -->
          {producto.categories[0] && (
            <a href={`/categoria/${producto.categories[0].slug}`} class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--theme-color)] bg-[var(--theme-color)]/5 px-3 py-1.5 rounded-full mb-4 hover:bg-[var(--theme-color)]/10 transition-colors">
              <i class="fas fa-tag text-xs"></i> {producto.categories[0].name}
            </a>
          )}

          <h1 class="font-['Rethink_Sans',sans-serif] text-3xl md:text-4xl font-bold mb-4 text-[#111] leading-tight">
            {producto.name}
          </h1>

          <!-- Short desc -->
          {producto.short_description && (
            <div class="mb-6 text-gray-600 leading-relaxed" set:html={producto.short_description} />
          )}

          <!-- Stock status -->
          <div class="flex items-center gap-4 mb-8">
            {producto.stock_status === 'instock' ? (
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 text-green-700 font-medium rounded-lg text-sm">
                <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse" aria-hidden="true"></span> Disponible
              </span>
            ) : (
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-red-50 text-red-600 font-medium rounded-lg text-sm">
                <span class="w-2 h-2 bg-red-500 rounded-full" aria-hidden="true"></span> Consultar disponibilidad
              </span>
            )}
            {producto.acf?.sku && (
              <span class="text-sm text-gray-400">SKU: {producto.acf.sku}</span>
            )}
          </div>

          <!-- CTA Box -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6">
            <div class="mb-4">
              <QuoteButton
                client:only="vue"
                productId={producto.id}
                productName={producto.name}
                productSlug={producto.slug}
                productImage={producto.images[0]?.src}
              />
            </div>
            <div class="flex items-center gap-3 text-sm text-gray-500">
              <div class="w-8 h-8 rounded-full bg-[var(--theme-color)]/10 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-clock text-[var(--theme-color)] text-xs"></i>
              </div>
              <span>Cotiza sin compromiso. Te responderemos en máximo 24 horas.</span>
            </div>
          </div>

          <!-- Trust badges -->
          <div class="grid grid-cols-3 gap-3 mb-8">
            <div class="flex flex-col items-center text-center p-3 rounded-xl bg-gray-50">
              <i class="fas fa-truck text-[var(--theme-color)] mb-2"></i>
              <span class="text-xs text-gray-600 font-medium">Despacho</span>
            </div>
            <div class="flex flex-col items-center text-center p-3 rounded-xl bg-gray-50">
              <i class="fas fa-shield-alt text-[var(--theme-color)] mb-2"></i>
              <span class="text-xs text-gray-600 font-medium">Calidad</span>
            </div>
            <div class="flex flex-col items-center text-center p-3 rounded-xl bg-gray-50">
              <i class="fas fa-headset text-[var(--theme-color)] mb-2"></i>
              <span class="text-xs text-gray-600 font-medium">Atención</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabs Section -->
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden mb-16">
        <!-- Tab headers -->
        <div class="flex border-b border-gray-200" role="tablist">
          <button id="tab-desc" class="tab-btn flex-1 py-4 px-6 text-sm font-semibold text-[var(--theme-color)] border-b-2 border-[var(--theme-color)] bg-[var(--theme-color)]/5 transition-colors" role="tab" aria-selected="true" onclick="switchTab('desc')">
            <i class="fas fa-align-left mr-2"></i>Descripción
          </button>
          {atributos.length > 0 && (
            <button id="tab-specs" class="tab-btn flex-1 py-4 px-6 text-sm font-semibold text-gray-500 border-b-2 border-transparent hover:text-[#111] transition-colors" role="tab" aria-selected="false" onclick="switchTab('specs')">
              <i class="fas fa-list-ul mr-2"></i>Especificaciones
            </button>
          )}
        </div>

        <!-- Tab panels -->
        <div class="p-6 lg:p-10">
          <div id="panel-desc" class="tab-panel" role="tabpanel">
            {producto.description ? (
              <div class="prose prose-agro max-w-none" set:html={producto.description} />
            ) : (
              <div class="text-center py-12">
                <i class="fas fa-file-alt text-4xl text-gray-200 mb-4"></i>
                <p class="text-gray-400">No hay descripción detallada para este producto.</p>
              </div>
            )}
          </div>

          {atributos.length > 0 && (
            <div id="panel-specs" class="tab-panel hidden" role="tabpanel">
              <div class="max-w-2xl">
                {atributos.map(attr => (
                  <div class="flex py-3 border-b border-gray-100 last:border-0">
                    <span class="w-1/3 text-sm font-medium text-gray-500">{attr.name}</span>
                    <span class="w-2/3 text-sm text-[#111] font-medium">{attr.options.join(', ')}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Related Products -->
      {relacionados.length > 0 && (
        <section class="mb-16">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-[#111] font-['Rethink_Sans',sans-serif]">Productos relacionados</h2>
            <a href={`/categoria/${producto.categories?.[0]?.slug || 'tienda'}`} class="text-sm font-semibold text-[var(--theme-color)] hover:underline flex items-center gap-1">
              Ver todos <i class="fas fa-arrow-right text-xs"></i>
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {relacionados.map(prod => (
              <ProductCard product={prod} client:load />
            ))}
          </div>
        </section>
      )}

      <!-- JSON-LD -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Product",
        "name": producto.name,
        "description": cleanDesc,
        "image": prodImage,
        "url": prodCanonical,
        ...(producto.categories[0] ? { "category": producto.categories[0].name } : {}),
        "offers": {
          "@type": "Offer",
          "availability": producto.stock_status === 'instock' ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
          "price": "0",
          "priceCurrency": "CLP",
          "priceSpecification": { "@type": "CompoundPriceSpecification", "description": "Consultar precio" }
        }
      })} />
    </div>
  </main>

  <Footer client:only="vue" />
</Layout>

<script is:inline>
function switchTab(tabId) {
  const panels = document.querySelectorAll('.tab-panel');
  const buttons = document.querySelectorAll('.tab-btn');
  
  panels.forEach(p => p.classList.add('hidden'));
  buttons.forEach(b => {
    b.classList.remove('text-[var(--theme-color)]', 'border-[var(--theme-color)]', 'bg-[var(--theme-color)]/5');
    b.classList.add('text-gray-500', 'border-transparent');
    b.setAttribute('aria-selected', 'false');
  });
  
  const panel = document.getElementById('panel-' + tabId);
  const btn = document.getElementById('tab-' + tabId);
  
  if (panel) panel.classList.remove('hidden');
  if (btn) {
    btn.classList.remove('text-gray-500', 'border-transparent');
    btn.classList.add('text-[var(--theme-color)]', 'border-[var(--theme-color)]', 'bg-[var(--theme-color)]/5');
    btn.setAttribute('aria-selected', 'true');
  }
}
</script>

<style>
  .tab-panel { animation: fadeIn 0.3s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
</style>