---
import Layout from '../../layouts/Layout.astro';
import HeaderUpper from '../../components/HeaderUpper.vue';
import HeaderLower from '../../components/HeaderLower.vue';
import QuoteButton from '../../components/QuoteButton.vue';
import Footer from '../../components/Footer.vue';
import { fetchProductos, fetchCategorias } from '../../lib/woocommerce';
import type { ProductoWC } from '../../lib/types';

const { url } = Astro;
const searchQuery = url.searchParams.get('search') || '';
const categoriaSlug = url.searchParams.get('categoria') || '';
const sortParam = url.searchParams.get('sort') || 'default';
const stockParam = url.searchParams.get('stock') || '';
const viewParam = url.searchParams.get('view') || 'grid';

let productos: ProductoWC[] = [];
let categorias: Array<{ id: number; name: string; slug: string; parent: number; count: number }> = [];
try {
  [productos, categorias] = await Promise.all([
    fetchProductos({ perPage: 50 }),
    fetchCategorias(),
  ]);
} catch {
  productos = [];
}

let filteredProducts = productos.filter(p => {
  if (categoriaSlug) {
    if (!p.categories?.some(c => c.slug === categoriaSlug)) return false;
  }
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    return p.name.toLowerCase().includes(q) || p.short_description?.toLowerCase().includes(q);
  }
  return true;
});

if (stockParam === 'available') {
  filteredProducts = filteredProducts.filter(p => p.stock_status === 'instock');
}

if (sortParam === 'name-asc') {
  filteredProducts.sort((a, b) => a.name.localeCompare(b.name));
} else if (sortParam === 'name-desc') {
  filteredProducts.sort((a, b) => b.name.localeCompare(a.name));
} else if (sortParam === 'stock') {
  filteredProducts.sort((a, b) => (a.stock_status === 'instock' ? -1 : 1) - (b.stock_status === 'instock' ? -1 : 1));
}

const pageTitle = searchQuery ? `Búsqueda: "${searchQuery}"` : categoriaSlug ? `Categoría: ${categoriaSlug}` : 'Tienda';
const pageDesc = searchQuery
  ? `Resultados de búsqueda para "${searchQuery}" en Agro Farías.`
  : 'Explora nuestra gama completa de productos agrícolas, fertilizantes, herbicidas, insecticidas y más.';

const parentCats = categorias.filter(c => c.parent === 0);

function buildFilterUrl(params: Record<string, string>): string {
  const p = new URLSearchParams();
  const cat = params.categoria || categoriaSlug;
  const search = params.search || searchQuery;
  const sort = params.sort || sortParam;
  const stock = params.stock || stockParam;
  const view = params.view || viewParam;
  if (cat) p.set('categoria', cat);
  if (search) p.set('search', search);
  if (sort !== 'default') p.set('sort', sort);
  if (stock === 'available') p.set('stock', stock);
  if (view !== 'grid') p.set('view', view);
  const qs = p.toString();
  return '/tienda' + (qs ? '?' + qs : '');
}
---

<Layout title={pageTitle} description={pageDesc}>
  <header class="main-header">
    <HeaderUpper client:only="vue" categorias={categorias} />
    <HeaderLower client:only="vue" />
  </header>

  <section class="bg-gradient-to-br from-[#2D6A4F]/5 via-white to-[#52B788]/5 py-10 border-b border-[#2D6A4F]/10">
    <div class="large-container">
      <div class="text-center text-[#111]">
        <h1 class="text-4xl md:text-5xl font-bold font-title mb-4 animate-fade-in-up">
          {searchQuery ? `Resultados para "${searchQuery}"` : 'Tienda'}
        </h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto animate-fade-in-up stagger-1">
          {searchQuery ? `Productos que coinciden con tu búsqueda` : 'Explora todos nuestros productos agrícolas'}
        </p>
      </div>
    </div>
  </section>

  <main class="py-12 min-h-[50vh]">
    <div class="large-container">
      <div class="flex flex-col md:flex-row gap-8">
        <!-- Sidebar -->
        <aside class="w-full md:w-64 flex-shrink-0" id="sidebar">
          <div class="bg-white rounded-2xl border border-gray-200 p-5 md:sticky md:top-24 space-y-6">
            <!-- Search -->
            <div>
              <h3 class="font-bold font-title text-[#111] mb-3 text-sm uppercase tracking-wider">Buscar</h3>
              <form action="/tienda" method="GET" role="search" id="search-form" class="relative">
                <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"></i>
                <input
                  type="search"
                  name="search"
                  id="search-input"
                  value={searchQuery}
                  placeholder="Buscar productos..."
                  class="w-full h-10 pl-9 pr-4 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-color)]/20 focus:border-[var(--theme-color)] placeholder-gray-400"
                  aria-label="Buscar productos"
                />
              </form>
            </div>

            <!-- Categories -->
            <div>
              <h3 class="font-bold font-title text-[#111] mb-3 text-sm uppercase tracking-wider">Categorías</h3>
              <nav class="flex flex-col gap-1.5" aria-label="Filtros de categoría">
                <a
                  href="/tienda"
                  class:list={['px-3 py-2 text-sm rounded-lg font-medium transition-all duration-200 flex items-center justify-between', !categoriaSlug && !searchQuery ? 'bg-[var(--theme-color)] text-white shadow-sm' : 'bg-gray-50 text-gray-700 hover:bg-gray-100']}
                >
                  <span>Todos</span>
                  <span class:list={['text-xs px-1.5 py-0.5 rounded-full', !categoriaSlug && !searchQuery ? 'bg-white/20' : 'bg-gray-200 text-gray-500']}>{productos.length}</span>
                </a>
                {parentCats.map(cat => (
                  <a
                    href={'/tienda?categoria=' + cat.slug}
                    class:list={['px-3 py-2 text-sm rounded-lg font-medium transition-all duration-200 flex items-center justify-between', categoriaSlug === cat.slug ? 'bg-[var(--theme-color)] text-white shadow-sm' : 'bg-gray-50 text-gray-700 hover:bg-gray-100']}
                  >
                    <span>{cat.name}</span>
                    <span class:list={['text-xs px-1.5 py-0.5 rounded-full', categoriaSlug === cat.slug ? 'bg-white/20' : 'bg-gray-200 text-gray-500']}>{cat.count}</span>
                  </a>
                ))}
              </nav>
            </div>

            <!-- Stock -->
            <div class="border-t border-gray-100 pt-5">
              <h3 class="font-bold font-title text-[#111] mb-3 text-sm uppercase tracking-wider">Disponibilidad</h3>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="checkbox" id="filter-stock" class="w-4 h-4 rounded border-gray-300 text-[var(--theme-color)] focus:ring-[var(--theme-color)]" checked={stockParam === 'available'} />
                <span class="text-sm text-gray-700 group-hover:text-[#111] transition-colors">Solo disponibles</span>
              </label>
            </div>

            <!-- Clear filters -->
            <div id="clear-filters" class:list={['border-t border-gray-100 pt-5', (!categoriaSlug && stockParam !== 'available' && !searchQuery) ? 'hidden' : '']}>
              <a href="/tienda" class="flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                <i class="fas fa-times" aria-hidden="true"></i>
                Limpiar filtros
              </a>
            </div>
          </div>
        </aside>

        <!-- Main content -->
        <div class="flex-1 min-w-0">
          <!-- Active filter chips -->
          <div id="active-chips" class="flex flex-wrap items-center gap-2 mb-4">
            {categoriaSlug && (
              <a href={buildFilterUrl({ categoria: '' })} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded-full hover:bg-gray-200 transition-colors">
                <span>{parentCats.find(c => c.slug === categoriaSlug)?.name || categoriaSlug}</span>
                <i class="fas fa-times text-xs text-gray-400" aria-hidden="true"></i>
              </a>
            )}
            {stockParam === 'available' && (
              <a href={buildFilterUrl({ stock: '' })} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded-full hover:bg-gray-200 transition-colors">
                <span>Solo disponibles</span>
                <i class="fas fa-times text-xs text-gray-400" aria-hidden="true"></i>
              </a>
            )}
            {searchQuery && (
              <a href={buildFilterUrl({ search: '' })} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded-full hover:bg-gray-200 transition-colors">
                <span>"{searchQuery}"</span>
                <i class="fas fa-times text-xs text-gray-400" aria-hidden="true"></i>
              </a>
            )}
            {(categoriaSlug || stockParam === 'available' || searchQuery) && (
              <a href="/tienda" class="text-sm text-red-600 hover:text-red-700 font-medium ml-1">Limpiar todo</a>
            )}
          </div>

          {filteredProducts.length > 0 ? (
            <>
              <!-- Toolbar -->
              <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6 bg-white rounded-xl border border-gray-200 p-4">
                <p class="text-sm text-gray-500">
                  <span class="font-semibold text-[#111]">{filteredProducts.length}</span> producto{filteredProducts.length !== 1 ? 's' : ''} encontrado{filteredProducts.length !== 1 ? 's' : ''}
                  {searchQuery && <span class="text-gray-400 ml-1">para "<span class="font-medium">{searchQuery}</span>"</span>}
                </p>
                <div class="flex items-center gap-3">
                  <!-- Sort -->
                  <div class="relative">
                    <select id="sort-select" class="appearance-none bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-lg pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-[var(--theme-color)]/20 focus:border-[var(--theme-color)] cursor-pointer">
                      <option value="default" selected={sortParam === 'default'}>Ordenar por: Relevancia</option>
                      <option value="name-asc" selected={sortParam === 'name-asc'}>Nombre: A-Z</option>
                      <option value="name-desc" selected={sortParam === 'name-desc'}>Nombre: Z-A</option>
                      <option value="stock" selected={sortParam === 'stock'}>Disponibilidad</option>
                    </select>
                    <i class="fas fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                  </div>

                  <!-- View toggle -->
                  <div class="flex bg-gray-100 rounded-lg p-0.5">
                    <button id="view-grid" class="view-btn w-9 h-9 rounded-md flex items-center justify-center text-sm transition-all" data-active={viewParam === 'grid' || !viewParam} aria-label="Vista de cuadrícula">
                      <i class="fas fa-th-large" aria-hidden="true"></i>
                    </button>
                    <button id="view-list" class="view-btn w-9 h-9 rounded-md flex items-center justify-center text-sm transition-all" data-active={viewParam === 'list'} aria-label="Vista de lista">
                      <i class="fas fa-list" aria-hidden="true"></i>
                    </button>
                  </div>
                </div>
              </div>

              <!-- Grid view -->
              <div id="products-grid" class:list={['grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-5 lg:gap-6', viewParam === 'list' ? 'hidden' : '']}>
                {filteredProducts.map(prod => (
                  <div class="shop-card group">
                    <div class="inner-box bg-white rounded-xl border border-gray-200 overflow-hidden transition-all duration-300 hover:shadow-lg hover:border-[var(--theme-color)]/30">
                      <figure class="relative overflow-hidden">
                        <a href={`/producto/${prod.slug}`}>
                          {prod.images[0] ? (
                            <img src={prod.images[0].src} alt={prod.name} loading="lazy" class="w-full h-48 sm:h-56 md:h-52 lg:h-48 object-cover transition-transform duration-500 group-hover:scale-105" />
                          ) : (
                            <div class="w-full h-48 sm:h-56 md:h-52 lg:h-48 bg-gray-100 flex items-center justify-center">
                              <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#9ca3af" stroke-width="1.5">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <circle cx="8.5" cy="8.5" r="1.5" />
                                <polyline points="21 15 16 10 5 21" />
                              </svg>
                            </div>
                          )}
                        </a>
                      </figure>
                      <div class="p-3 flex flex-col flex-1">
                        {prod.categories[0] && <span class="block text-[11px] uppercase tracking-wider text-[var(--theme-color)] mb-1 font-semibold">{prod.categories[0].name}</span>}
                        <h4 class="mb-2">
                          <a href={`/producto/${prod.slug}`} class="text-sm font-bold text-[#111] hover:text-[var(--theme-color)] transition-colors line-clamp-2 leading-snug">{prod.name}</a>
                        </h4>
                        <div class="flex items-center justify-between mb-2">
                          {prod.stock_status === 'instock' ? (
                            <span class="inline-flex items-center gap-1 text-xs font-bold text-green-600" role="status">
                              <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse" aria-hidden="true"></span> Disponible
                            </span>
                          ) : (
                            <span class="inline-flex items-center gap-1 text-xs font-bold text-red-500" role="status">
                              <span class="w-1.5 h-1.5 bg-red-500 rounded-full" aria-hidden="true"></span> Consultar
                            </span>
                          )}
                        </div>
                        <div class="mt-auto">
                          <QuoteButton client:only="vue" product-id={prod.id} product-name={prod.name} product-slug={prod.slug} product-image={prod.images[0]?.src ?? ''} />
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <!-- List view -->
              <div id="products-list" class:list={['space-y-3', viewParam !== 'list' ? 'hidden' : '']}>
                {filteredProducts.map(prod => (
                  <a href={`/producto/${prod.slug}`} class="group flex items-center gap-4 p-4 bg-white rounded-xl border border-gray-200 hover:border-[var(--theme-color)]/30 hover:shadow-lg transition-all">
                    <div class="w-20 h-20 flex-shrink-0 rounded-lg overflow-hidden bg-gray-50">
                      {prod.images[0] ? (
                        <img src={prod.images[0].src} alt={prod.name} class="w-full h-full object-contain p-2 group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center text-gray-300"><i class="fas fa-image text-xl"></i></div>
                      )}
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-semibold text-[#111] group-hover:text-[var(--theme-color)] transition-colors truncate">{prod.name}</h3>
                      {prod.categories[0] && <span class="text-xs text-gray-500 mt-1 inline-block">{prod.categories[0].name}</span>}
                    </div>
                    <div class="flex-shrink-0 flex items-center gap-3">
                      {prod.stock_status === 'instock' ? (
                        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
                          <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> Disponible
                        </span>
                      ) : (
                        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-red-600 bg-red-50 px-2.5 py-1 rounded-full">
                          <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span> Consultar
                        </span>
                      )}
                      <i class="fas fa-chevron-right text-gray-300 group-hover:text-[var(--theme-color)] group-hover:translate-x-1 transition-all"></i>
                    </div>
                  </a>
                ))}
              </div>
            </>
          ) : (
            <div class="text-center py-16 bg-white rounded-2xl border border-gray-200">
              <i class="fas fa-search text-5xl text-gray-300 block mb-4"></i>
              <p class="text-lg text-gray-500 mb-2">No se encontraron productos</p>
              <p class="text-sm text-gray-500 mb-6">Intenta con otros términos o explora nuestras categorías.</p>
              <a href="/tienda" class="theme-btn btn-one inline-flex">Ver todos los productos</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>

  <Footer client:only="vue" />
</Layout>

<script is:inline>
(function() {
  const stockCheckbox = document.getElementById('filter-stock');
  const sortSelect = document.getElementById('sort-select');
  const gridBtn = document.getElementById('view-grid');
  const listBtn = document.getElementById('view-list');
  const gridView = document.getElementById('products-grid');
  const listView = document.getElementById('products-list');
  const searchForm = document.getElementById('search-form');
  const searchInput = document.getElementById('search-input');

  function getCurrentParams() {
    const u = new URL(window.location.href);
    return {
      categoria: u.searchParams.get('categoria') || '',
      search: u.searchParams.get('search') || '',
      sort: u.searchParams.get('sort') || 'default',
      stock: u.searchParams.get('stock') || '',
      view: u.searchParams.get('view') || 'grid',
    };
  }

  function buildUrl(overrides) {
    const p = getCurrentParams();
    const sort = overrides.sort !== undefined ? overrides.sort : (sortSelect ? sortSelect.value : p.sort);
    const stock = overrides.stock !== undefined ? overrides.stock : (stockCheckbox && stockCheckbox.checked ? 'available' : '');
    const view = overrides.view !== undefined ? overrides.view : (p.view || 'grid');
    const search = overrides.search !== undefined ? overrides.search : p.search;
    const categoria = overrides.categoria !== undefined ? overrides.categoria : p.categoria;

    const params = new URLSearchParams();
    if (categoria) params.set('categoria', categoria);
    if (search) params.set('search', search);
    if (sort && sort !== 'default') params.set('sort', sort);
    if (stock) params.set('stock', stock);
    if (view && view !== 'grid') params.set('view', view);

    const qs = params.toString();
    return '/tienda' + (qs ? '?' + qs : '');
  }

  function applyFilters() {
    window.location.href = buildUrl({});
  }

  function setView(view) {
    if (!gridBtn || !listBtn || !gridView || !listView) return;
    if (view === 'grid') {
      gridBtn.setAttribute('data-active', 'true');
      listBtn.setAttribute('data-active', 'false');
      gridBtn.classList.add('bg-white', 'shadow-sm', 'text-[var(--theme-color)]');
      gridBtn.classList.remove('text-gray-500', 'hover:text-[#111]');
      listBtn.classList.remove('bg-white', 'shadow-sm', 'text-[var(--theme-color)]');
      listBtn.classList.add('text-gray-500', 'hover:text-[#111]');
      gridView.classList.remove('hidden');
      listView.classList.add('hidden');
    } else {
      listBtn.setAttribute('data-active', 'true');
      gridBtn.setAttribute('data-active', 'false');
      listBtn.classList.add('bg-white', 'shadow-sm', 'text-[var(--theme-color)]');
      listBtn.classList.remove('text-gray-500', 'hover:text-[#111]');
      gridBtn.classList.remove('bg-white', 'shadow-sm', 'text-[var(--theme-color)]');
      gridBtn.classList.add('text-gray-500', 'hover:text-[#111]');
      listView.classList.remove('hidden');
      gridView.classList.add('hidden');
    }
  }

  // Init view toggle based on URL param
  const curView = getCurrentParams().view;
  setView(curView === 'list' ? 'list' : 'grid');

  // Search form: preserve all existing filters
  if (searchForm && searchInput) {
    searchForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const query = searchInput.value.trim();
      window.location.href = buildUrl({ search: query });
    });
  }

  if (gridBtn) gridBtn.addEventListener('click', function() { setView('grid'); applyFilters(); });
  if (listBtn) listBtn.addEventListener('click', function() { setView('list'); applyFilters(); });
  if (stockCheckbox) stockCheckbox.addEventListener('change', applyFilters);
  if (sortSelect) sortSelect.addEventListener('change', applyFilters);
})();
</script>

<style is:global>
  .shop-card { width: 100%; height: 100%; display: flex; }
  .inner-box { display: flex; flex-direction: column; height: 100%; }
</style>
