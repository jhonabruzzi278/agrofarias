---
import Layout from '../layouts/Layout.astro';
import HeaderUpper from '../components/HeaderUpper.vue';
import HeaderLower from '../components/HeaderLower.vue';
import QuoteForm from '../components/QuoteForm.vue';
import Footer from '../components/Footer.vue';
import { fetchCategorias } from '../lib/woocommerce';

export const prerender = false;

let categorias: Array<{ id: number; name: string; slug: string; parent: number }> = [];
try { categorias = await fetchCategorias(); } catch (e) { console.error('[cotizar] Failed to fetch categories:', e); categorias = []; }
---

<Layout title="Solicitar Presupuesto" description="Completa el formulario para solicitar un presupuesto personalizado de productos agrícolas. Te responderemos en máximo 24 horas." canonical="https://agrofarias.cl/cotizar">
  <header class="main-header">
    <HeaderUpper client:only="vue" categorias={categorias} />
    <HeaderLower client:only="vue" />
  </header>

  <section class="bg-gradient-to-br from-[#2D6A4F]/5 via-white to-[#52B788]/5 py-10 border-b border-[#2D6A4F]/10">
    <div class="large-container">
      <div class="text-center text-[#111]">
        <h1 class="text-4xl font-bold font-title mb-4 animate-fade-in-up">Solicitar Presupuesto</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto animate-fade-in-up stagger-1">Completa tus datos y te enviaremos una cotización personalizada a la brevedad.</p>
      </div>
    </div>
  </section>

  <main class="py-12 min-h-[60vh]">
    <div class="large-container max-w-[720px]">
      <QuoteForm client:only="vue" />
    </div>
  </main>

  <Footer client:only="vue" categorias={categorias} />
</Layout>
