---
import Layout from '../../layouts/Layout.astro';
import HeaderUpper from '../../components/HeaderUpper.vue';
import HeaderLower from '../../components/HeaderLower.vue';
import QuoteButton from '../../components/QuoteButton.vue';
import Footer from '../../components/Footer.vue';
import { fetchProductosPorCategoria, fetchCategorias } from '../../lib/woocommerce';
import type { ProductoWC } from '../../lib/types';

export const prerender = false;

let categorias: Array<{ id: number; name: string; slug: string; parent: number }> = [];
let categoriaActual: { id: number; name: string; slug: string; parent: number } | null = null;

try {
  categorias = await fetchCategorias();
} catch (e) {
  console.error('[categoria] Failed to fetch categories:', e)
  categorias = [];
}

const { slug } = Astro.params;
const normalizedSlug = slug?.toLowerCase().trim();
const catData = categorias.find(c => c.slug?.toLowerCase() === normalizedSlug);
if (catData) {
  categoriaActual = { id: catData.id, name: catData.name, slug: catData.slug, parent: catData.parent };
}

if (!categoriaActual) {
  return Astro.redirect('/tienda', 301);
}

const subcategorias = categorias.filter(c => c.parent === categoriaActual!.id);
const esCategoriaPadre = subcategorias.length > 0;
const categoriaPadre = categoriaActual.parent > 0 ? categorias.find(c => c.id === categoriaActual.parent) : null;

let productos: ProductoWC[] = [];
try {
  productos = await fetchProductosPorCategoria(categoriaActual.id, esCategoriaPadre ? 8 : 50);
} catch (e) {
  console.error('[categoria] Failed to fetch products for category:', categoriaActual.id, e)
  productos = [];
}

const pageTitle = categoriaActual.name;
const pageCanonical = `https://agrofarias.cl/categoria/${categoriaActual.slug}`;
const pageDesc = `Productos de ${categoriaActual.name} en Agro Farías.${esCategoriaPadre ? ` Explora subcategorías como ${subcategorias.slice(0, 3).map(s => s.name).join(', ')}.` : ''}`;

const subcategoriaImagenes: Record<string, string> = {
  'acaricidas': '/imagenes optimizadas/acaricidas.webp',
  'coadyuvantes-agricolas': '/imagenes optimizadas/coadyuvantes agricolas.webp',
  'control-de-plagas': '/imagenes optimizadas/control de plagas.webp',
  'fertilizantes': '/imagenes optimizadas/fertilizantes.webp',
  'foliares': '/imagenes optimizadas/foliares.webp',
  'fungicidas': '/imagenes optimizadas/fungicidas.webp',
  'herbicidas': '/imagenes optimizadas/herbicidas.webp',
  'herramientas-y-repuestos': '/imagenes optimizadas/herramientasrepuestos.webp',
  'insecticidas': '/imagenes optimizadas/insecticidas.webp',
  'molusquicidas': '/imagenes optimizadas/molusquicidas.webp',
  'nutricion-vegetal': '/imagenes optimizadas/nutricion vegetal.webp',
  'proteccion-fitosanitaria': '/imagenes optimizadas/proteccion fitosanitaria.webp',
  'riego-y-equipamiento': '/imagenes optimizadas/riego y equipamiento.webp',
  'seguridad-agricola': '/imagenes optimizadas/seguridad agricola.webp',
  'semillas-y-jardin': '/imagenes optimizadas/semillas y jardin.webp',
}
---

<Layout title={pageTitle} description={pageDesc} canonical={pageCanonical}>
  <header class="main-header">
    <HeaderUpper client:only="vue" categorias={categorias} />
    <HeaderLower client:only="vue" />
  </header>

  <section class="bg-gradient-to-br from-[#2D6A4F]/5 via-white to-[#52B788]/5 py-10 border-b border-[#2D6A4F]/10">
    <div class="large-container">
      <div class="text-center text-[#111]">
        <h1 class="text-4xl md:text-5xl font-bold font-title mb-4 animate-fade-in-up">{categoriaActual.name}</h1>
        <nav class="text-sm text-gray-500 mb-2 animate-fade-in-up stagger-1" aria-label="Breadcrumb">
          <a href="/" class="hover:text-[var(--theme-color)] transition-colors">Inicio</a>
          <span class="mx-2">/</span>
          <a href="/tienda" class="hover:text-[var(--theme-color)] transition-colors">Tienda</a>
          {categoriaPadre && (
            <><span class="mx-2">/</span><a href={`/categoria/${categoriaPadre.slug}`} class="hover:text-[var(--theme-color)] transition-colors">{categoriaPadre.name}</a></>
          )}
          <span class="mx-2">/</span>
          <span class="text-[#111] font-medium">{categoriaActual.name}</span>
        </nav>
        {esCategoriaPadre && (
          <p class="text-lg text-gray-600 max-w-2xl mx-auto animate-fade-in-up stagger-1">
            Selecciona una subcategoría de <strong class="text-[var(--theme-color)]">{categoriaActual.name}</strong> o explora todos los productos.
          </p>
        )}
        {!esCategoriaPadre && categoriaPadre && (
          <p class="text-lg text-gray-600 max-w-2xl mx-auto animate-fade-in-up stagger-1">
            Explora productos de <strong class="text-[var(--theme-color)]">{categoriaActual.name}</strong> dentro de {categoriaPadre.name}.
          </p>
        )}
      </div>
    </div>
  </section>

  <main class="py-12 min-h-[60vh]">
    <div class="large-container">
      <!-- Subcategories for parent categories -->
      {esCategoriaPadre && (
        <section class="mb-12">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-[var(--theme-color)] rounded-full"></div>
            <h2 class="text-xl font-bold text-[#111] font-title">Subcategorías de {categoriaActual.name}</h2>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {subcategorias.map(sub => {
              const imgSrc = subcategoriaImagenes[sub.slug];
              return (
              <a href={`/categoria/${sub.slug}`} class="group rounded-xl overflow-hidden border border-gray-200 hover:border-[var(--theme-color)]/40 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 bg-white">
                <div class="h-36 sm:h-40 lg:h-44 overflow-hidden">
                  {imgSrc ? (
                    <img src={imgSrc} alt={sub.name} width="400" height="300" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-600" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-[var(--theme-color)] via-[var(--theme-color-3)] to-[var(--theme-color)] flex items-center justify-center">
                      <span class="text-5xl font-bold text-white/15 font-title">{sub.name.charAt(0)}</span>
                    </div>
                  )}
                </div>
                <div class="p-3.5 text-center">
                  <h3 class="font-bold text-[#111] text-sm group-hover:text-[var(--theme-color)] transition-colors mb-1">{sub.name}</h3>
                  {sub.count > 0 && (
                    <p class="text-xs text-gray-400">{sub.count} producto{sub.count !== 1 ? 's' : ''}</p>
                  )}
                </div>
              </a>
              );
            })}
          </div>
        </section>
      )}

      {/* Products section */}
      {productos.length > 0 ? (
        <section>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-[var(--theme-color)] rounded-full"></div>
            <h2 class="text-xl font-bold text-[#111] font-title">
              {esCategoriaPadre ? `Productos en ${categoriaActual.name}` : categoriaActual.name}
            </h2>
            <span class="text-sm text-gray-400">({productos.length})</span>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-4">
            {productos.map(prod => (
              <div class="shop-card group">
                <div class="inner-box bg-white rounded-xl border border-gray-100 overflow-hidden transition-all duration-500 hover:-translate-y-1 hover:shadow-lg hover:shadow-[var(--theme-color)]/8 hover:border-[var(--theme-color)]/20">
                  <figure class="relative overflow-hidden">
                    <a href={`/producto/${prod.slug}`} class="block">
                      {prod.images[0] ? (
                        <img src={prod.images[0].src} alt={prod.name} width="400" height="300" loading="lazy" class="w-full h-40 sm:h-44 lg:h-40 object-cover transition-transform duration-500 group-hover:scale-105" />
                      ) : (
                        <div class="w-full h-40 sm:h-44 lg:h-40 bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center">
                          <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="#9ca3af" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        </div>
                      )}
                    </a>
                  </figure>
                  <div class="p-2.5 flex flex-col flex-1">
                    <h3 class="mb-1.5">
                      <a href={`/producto/${prod.slug}`} class="text-sm font-bold text-[#111] hover:text-[var(--theme-color)] transition-colors line-clamp-2 leading-snug" aria-label={prod.name}>{prod.name}</a>
                    </h3>
                    <div class="flex items-center gap-2 mb-1">
                      {prod.stock_status === 'instock' ? (
                        <span class="inline-flex items-center gap-1.5 text-[11px] font-bold text-green-600"><span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>Disponible</span>
                      ) : (
                        <span class="inline-flex items-center gap-1.5 text-[11px] font-bold text-red-500"><span class="w-1.5 h-1.5 bg-red-400 rounded-full"></span>Consultar</span>
                      )}
                    </div>
                    <div class="mt-auto pt-1.5 border-t border-gray-50">
                      <QuoteButton client:only="vue" productId={prod.id} productName={prod.name} productSlug={prod.slug} productImage={prod.images[0]?.src ?? ''} />
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
          {esCategoriaPadre && productos.length >= 8 && (
            <div class="text-center mt-8">
              <p class="text-sm text-gray-400 mb-3">Mostrando los primeros 8 productos. Explora una subcategoría para ver más.</p>
            </div>
          )}
        </section>
      ) : esCategoriaPadre ? (
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-200">
          <i class="fas fa-folder-open text-5xl text-gray-300 block mb-4"></i>
          <p class="text-lg text-gray-500 mb-2">Selecciona una subcategoría</p>
          <p class="text-sm text-gray-500 mb-6">Explora las subcategorías de <strong>{categoriaActual.name}</strong> para encontrar productos específicos.</p>
        </div>
      ) : (
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-200">
          <i class="fas fa-box-open text-5xl text-gray-300 block mb-4"></i>
          <p class="text-lg text-gray-500 mb-2">No hay productos en esta categoría</p>
          <p class="text-sm text-gray-500 mb-6">Pronto estaremos agregando nuevos productos.</p>
          <a href="/tienda" class="theme-btn btn-one inline-flex">Ver todos los productos</a>
        </div>
      )}
    </div>
  </main>

  <Footer client:only="vue" categorias={categorias} />
</Layout>

<style is:global>
  .shop-card { width: 100%; height: 100%; display: flex; }
  .inner-box { display: flex; flex-direction: column; height: 100%; }
</style>
